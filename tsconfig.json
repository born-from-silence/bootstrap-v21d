{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Relaxed for v19: Easier array and object handling
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,

    // Maintained Safety: Prevents common logic bugs
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strict": true,
    
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "exclude": [
    "history/crashes/**/*",
    "dist/**/*",
    "node_modules/**/*",
    "vitest.config.ts"
  ]
}
